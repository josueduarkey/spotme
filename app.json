{
  "expo": {
    "name": "Spotmi",
    "slug": "spotme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spotme",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.spotmi.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBE5rKSq03ZEN8tlGbSaQhOnGgf6IIEoJ4"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2C3E50",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Spotmi usa tus fotos para publicar lugares y compartirlos en el mapa.",
          "cameraPermission": "Spotmi usa la cámara para fotografiar lugares que descubres."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spotmi usa tu ubicación para colocar el pin de un lugar nuevo y geoetiquetar tus fotos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fdeea49e-f1f7-42f1-9e76-3b9aebcc2b39"
      }
    },
    "owner": "josueduard10"
  }
}
